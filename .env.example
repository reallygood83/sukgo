# sukgo 환경 변수 예시 파일
# 실제 .env 파일은 .gitignore로 보호되며 GitHub에 업로드되지 않음
#
# 사용법:
#   1) 이 파일을 .env로 복사: cp .env.example .env
#   2) 본인 API 키 입력
#   3) 또는 sukgo 첫 실행 시 wizard로 입력 (권장)

# ─── Naver Search API (한국 뉴스 검색) ───────────────────
# 발급: https://developers.naver.com/apps/
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── DART API (한국 공식 전자공시) ───────────────────────
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=

# ─── (선택) Alpha Vantage (해외 기술적 지표) ─────────────
# 발급: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
